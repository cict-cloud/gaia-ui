{
  "name": "@converge-cloudops/gaia-ui",
  "version": "0.3.10",
  "description": "Shared UI shell components for GAIA-based projects",
  "homepage": "https://github.com/cict-cloud/gaia-ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/cict-cloud/gaia-ui.git"
  },
  "bugs": {
    "url": "https://github.com/cict-cloud/gaia-ui/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/gaia-ui.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@mantine/core": ">=8.0.0",
    "@mantine/hooks": ">=8.0.0",
    "@reduxjs/toolkit": ">=2",
    "@tabler/icons-react": ">=3.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "react-redux": ">=9.2.0",
    "react-router": ">=7.12.0"
  },
  "peerDependenciesMeta": {
    "react-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mantine/core": "8.3.14",
    "@mantine/hooks": "8.3.14",
    "@tabler/icons-react": "3.36.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@reduxjs/toolkit": "^2",
    "@vitejs/plugin-react": "^5.0.0",
    "postcss": "^8.5.0",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-redux": "^9.2.0",
    "react-router": "7.12.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "keywords": [
    "gaia",
    "ui",
    "mantine",
    "react",
    "components"
  ],
  "author": "",
  "license": "ISC"
}
