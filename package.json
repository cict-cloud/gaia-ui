{
  "name": "@converge-cloudops/gaia-ui",
  "version": "0.1.0",
  "description": "Shared UI shell components for GAIA-based projects",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@mantine/core": "8.3.14",
    "@mantine/hooks": "8.3.14",
    "@tabler/icons-react": "3.36.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "7.9.1"
  },
  "peerDependenciesMeta": {
    "react-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mantine/core": "8.3.14",
    "@mantine/hooks": "8.3.14",
    "@tabler/icons-react": "3.36.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "7.9.1",
    "rimraf": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "gaia",
    "ui",
    "mantine",
    "react",
    "components"
  ],
  "author": "",
  "license": "ISC"
}
